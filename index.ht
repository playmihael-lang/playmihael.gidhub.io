<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PC Market — Магазин Компьютеров</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background-color: #121214;
            color: #fff;
            padding-bottom: 60px;
        }

        header {
            background-color: #1a1a1e;
            padding: 20px;
            text-align: center;
            border-bottom: 2px solid #333;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        header h1 {
            color: #00ff88;
            font-size: 2rem;
        }

        .container {
            max-width: 1200px;
            margin: 30px auto;
            padding: 0 20px;
            display: grid;
            grid-template-columns: 3fr 1fr;
            gap: 30px;
        }

        @media (max-width: 900px) {
            .container {
                grid-template-columns: 1fr;
            }
        }

        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 25px;
        }

        .product-card {
            background-color: #1a1a1e;
            border: 1px solid #2a2a30;
            border-radius: 12px;
            padding: 20px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            transition: transform 0.2s, border-color 0.2s;
        }

        .product-card:hover {
            transform: translateY(-5px);
            border-color: #00ff88;
        }

        .product-badge {
            background: #00ff88;
            color: #000;
            font-weight: bold;
            padding: 5px 10px;
            border-radius: 6px;
            align-self: flex-start;
            font-size: 0.8rem;
            margin-bottom: 15px;
        }

        .product-title {
            font-size: 1.3rem;
            margin-bottom: 10px;
        }

        .product-specs {
            font-size: 0.9rem;
            color: #aaa;
            margin-bottom: 20px;
            line-height: 1.4;
        }

        .product-price {
            font-size: 1.5rem;
            font-weight: bold;
            color: #00ff88;
            margin-bottom: 15px;
        }

        .btn {
            background-color: #00ff88;
            color: #000;
            border: none;
            padding: 12px;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.2s;
            width: 100%;
        }

        .btn:hover {
            background-color: #00cc6e;
        }

        /* Корзина */
        .cart-sidebar {
            background-color: #1a1a1e;
            border: 1px solid #2a2a30;
            border-radius: 12px;
            padding: 20px;
            height: fit-content;
            position: sticky;
            top: 100px;
        }

        .cart-title {
            font-size: 1.4rem;
            margin-bottom: 15px;
            border-bottom: 1px solid #333;
            padding-bottom: 10px;
            color: #00ff88;
        }

        .cart-items {
            max-height: 300px;
            overflow-y: auto;
            margin-bottom: 15px;
        }

        .cart-item {
            display: flex;
            justify-content: space-between;
            font-size: 0.9rem;
            margin-bottom: 10px;
            background: #25252b;
            padding: 8px;
            border-radius: 6px;
        }

        .cart-total {
            font-size: 1.2rem;
            font-weight: bold;
            margin-top: 15px;
            display: flex;
            justify-content: space-between;
        }

        .checkout-btn {
            background-color: #ff3366;
            color: white;
            margin-top: 15px;
        }

        .checkout-btn:hover {
            background-color: #e02253;
        }
    </style>
</head>
<body>

    <header>
        <h1>🖥️ PC NEXT-GEN MARKET</h1>
        <p>Выбери свой идеальный компьютер</p>
    </header>

    <div class="container">
        <main class="products-grid">
            
            <div class="product-card">
                <div>
                    <span class="product-badge">TOP GAMING</span>
                    <h2 class="product-title">Cyber Gaming Pro</h2>
                    <p class="product-specs">
                        • RTX 4070 Ti 12GB<br>
                        • Intel Core i7-14700K<br>
                        • 32GB DDR5 RAM<br>
                        • 1TB NVMe SSD
                    </p>
                </div>
                <div>
                    <div class="product-price">185 000 ₽</div>
                    <button class="btn" onclick="addToCart('Cyber Gaming Pro', 185000)">В корзину</button>
                </div>
            </div>

            <div class="product-card">
                <div>
                    <span class="product-badge" style="background: #00bcd4;">WORKSTATION</span>
                    <h2 class="product-title">Ultra Render Station</h2>
                    <p class="product-specs">
                        • RTX 4090 24GB<br>
                        • AMD Ryzen 9 7950X<br>
                        • 64GB DDR5 RAM<br>
                        • 2TB NVMe SSD
                    </p>
                </div>
                <div>
                    <div class="product-price">340 000 ₽</div>
                    <button class="btn" onclick="addToCart('Ultra Render Station', 340000)">В корзину</button>
                </div>
            </div>

            <div class="product-card">
                <div>
                    <span class="product-badge" style="background: #ffb300;">OFFICE / HOME</span>
                    <h2 class="product-title">Офис Стандарт</h2>
                    <p class="product-specs">
                        • Intel Core i3-12100<br>
                        • Intel UHD Graphics<br>
                        • 16GB DDR4 RAM<br>
                        • 512GB SSD
                    </p>
                </div>
                <div>
                    <div class="product-price">35 000 ₽</div>
                    <button class="btn" onclick="addToCart('Офис Стандарт', 35000)">В корзину</button>
                </div>
            </div>

            <div class="product-card">
                <div>
                    <span class="product-badge">POPULAR</span>
                    <h2 class="product-title">Cyber Gaming Light</h2>
                    <p class="product-specs">
                        • RTX 4060 8GB<br>
                        • AMD Ryzen 5 5600X<br>
                        • 16GB DDR4 RAM<br>
                        • 1TB NVMe SSD
                    </p>
                </div>
                <div>
                    <div class="product-price">85 000 ₽</div>
                    <button class="btn" onclick="addToCart('Cyber Gaming Light', 85000)">В корзину</button>
                </div>
            </div>

        </main>

        <aside class="cart-sidebar">
            <h2 class="cart-title">🛒 Ваша корзина</h2>
            <div class="cart-items" id="cartItems">
                <p style="color: #666; text-align: center;" id="emptyMessage">Корзина пуста</p>
            </div>
            <div class="cart-total">
                <span>Итого:</span>
                <span id="totalPrice">0 ₽</span>
            </div>
            <button class="btn checkout-btn" onclick="checkout()">Оформить заказ</button>
        </aside>
    </div>

    <script>
        let cart = [];
        let total = 0;

        function addToCart(name, price) {
            cart.push({ name, price });
            total += price;
            updateCartUI();
        }

        function updateCartUI() {
            const cartItemsContainer = document.getElementById('cartItems');
            const totalPriceContainer = document.getElementById('totalPrice');
            const emptyMessage = document.getElementById('emptyMessage');

            if (cart.length > 0) {
                emptyMessage.style.display = 'none';
            } else {
                emptyMessage.style.display = 'block';
            }

            // Очищаем старые элементы, кроме сообщения о пустоте
            cartItemsContainer.querySelectorAll('.cart-item').forEach(el => el.remove());

            // Добавляем актуальные элементы
            cart.forEach(item => {
                const itemElement = document.createElement('div');
                itemElement.classList.add('cart-item');
                itemElement.innerHTML = `
                    <span>${item.name}</span>
                    <span style="color: #00ff88;">${item.price.toLocaleString()} ₽</span>
                `;
                cartItemsContainer.appendChild(itemElement);
            });

            totalPriceContainer.innerText = ${total.toLocaleString()} ₽;
        }

        function checkout() {
            if (cart.length === 0) {
                alert('Добавьте хотя бы один компьютер в корзину!');
                return;
            }
            alert(Спасибо за заказ! Общая сумма: ${total.toLocaleString()} ₽. Мы свяжемся с вами (это демо-версия).);
            // Очистка корзины после "покупки"
            cart = [];
            total = 0;
            updateCartUI();
        }
    </script>
</body>
</html>